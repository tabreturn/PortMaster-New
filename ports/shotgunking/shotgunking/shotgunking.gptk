[config]
deadzone_triggers = 3000
mouse_scale = 6114
mouse_delay = 16
mouse_slow_scale = 50
dpad_mouse_normalize = true

# Default state: pass everything through to the game.
# exclusive = false means gptokeyb2 does NOT grab the controller, so the
# game keeps receiving native gamepad events for unmapped buttons. Only
# L2 is consumed here, to enter the mouse overlay below.
[controls]
overlay = clear
exclusive = false

l2 = hold_state mouse_mode

# While L2 is held: grab the controller so the dpad and click buttons
# stop reaching the game, and drive the mouse from the dpad. Releasing
# L2 pops back to [controls] and ungrabs.
[controls:mouse_mode]
overlay = clear
exclusive = true

dpad = mouse_movement

a  = mouse_left
b  = mouse_right
r1 = mouse_slow
r2 = mouse_left   # Fire while aiming
