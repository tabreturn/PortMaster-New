

%string ca_audioHead "AUDIOHED.CK4" #MOD: Uses AUDIOHED for compressed headers.
%string ca_mapFile "editmaps.ck4"
%string ca_tileInfo "Keen4.tli"


# Default High Scores
# -------------------

%stringarray ck_defaultHighScoreNames
	"Commander Keen   ",
	"Tom Hall         ",
	"Ceilick          ",
	"Keenrush         ",
	"Levellass        ",
	"Xky Rauh         ",
	"Adurdin          ",
	"Commander Spleen "



# We disable the underwater camera level so we get normal exits out the sides.
# The original game disables this by removing the jump, we just make it 0 to match
# the world map (which uses this regardless.)
%int CK4_UnderwaterCameraLevel 0
%int CK4_JanitorLevel 14
%int CK4_NumCouncilsToRescue 7

# Music Table
# -----------
%int ONTHERUN_MUS 0 # On the Run
%int VOODOO_MUS 1 # Ceilick Vodoo
%int RUSHIN_MUS 2 # Keen Rushin'
%int TOOQUIET_MUS 3 # It's Quiet... Too Quiet
%int INFERNO_MUS 4 # Into the Inferno
%int SUCCESS_MUS 5 # The Key to Success


%intarray CK_LevelMusic	@ONTHERUN_MUS, # Map
			@TOOQUIET_MUS, # Blue Forest
			@VOODOO_MUS,   # Forest Tunnels
			@INFERNO_MUS,  # Private Manor
			@RUSHIN_MUS,   # Mansion
			@INFERNO_MUS,  # Complex
			@TOOQUIET_MUS, # Mushroom Forest
			@VOODOO_MUS,   # Cliff Hangar
			@RUSHIN_MUS,   # Underground
			@RUSHIN_MUS,   # Monk's House
			@VOODOO_MUS,   # Gem Temple
			@TOOQUIET_MUS, # Forest Skies
			@INFERNO_MUS,  # Slime Temple
			@RUSHIN_MUS,   # Fun House
			@INFERNO_MUS,  # Stone Temple
			@TOOQUIET_MUS, # Slime Lake
			@RUSHIN_MUS,   # Shoal
			@VOODOO_MUS,   # Reef
			@TOOQUIET_MUS, # BwB Megarocket
			-1 # Should be @SUCCESS_MUS, but fixed up in code?
%int ck4_specialMusic @SUCCESS_MUS


%int CK4_MushroomNumJumps 2 # MOD: Length of a Hop-Hop-Jump cycle
%int CK4_BirdHatchYOffset 0x100
%int CK4_BounderDeathHopVelocity -64 # MOD: $11179
%int CK4_BounderBounceYVelocity -38

%int CK4_LickLongHopYVelocity -64
%int CK4_LickShortHopYVelocity -32
%int CK4_LindseyMessage1Level 6

