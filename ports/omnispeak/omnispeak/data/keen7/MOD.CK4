%stringarray ck_str_levelEntryText
	"Keen explores\n"
	"planet Krodacia\n",

	"Keen wanders through \n the Blue Forest",

	"Keen descends the\n Forest Tunnel",

	"Keen breaks \n into the Private Manor",

	"Keen shoots his way \n through the Mansion",

	"Keen sneaks into \n the complex",

	"Keen nervously enters\n the Mushroom Forest",

	"Keen scales the\n Cliff Hanger",

	"Keen wanders through\n	the Underground",

	"Keen ransacks\n Monk's House",

	"Keen purposefully\n enters the Gem Temple",

	"Keen regrets going\n into the Forest Skies",

	"Keen dodges slime\n pools in the Slime Temple",

	"Keen gets lost\n in the Fun House",

	"Keen hesitently enters\n the Stone Temple",

	"Keen takes a swim\n in Slime Lake",

	"Keen dives into\n the Shoal",

	"Keen treads water\n in the Reef",

	"Keen launches into the\n"
	"Bean-with-Bacon\n"
	"Megarocket"

%string ck_str_storyText
	"Episode Seven\n"
	"        \n"
	"The Keys of Krodacia\n"
	"        \n"
	"After learning that\n"
	"his arch enemy\n"
	"Mortimer McMire is \n"
	"  still alive Commander  \n"
	"Keen looks for\n"
	"clues and makes the\n"
	"discovery that\n"
	"Mortimer plans to\n"
	"destroy the Universe!\n"
	"                     \n"
	"Once at Mortimer's\n"
	"base, located\n"
	"on planet Krodacia,\n"
	"he\n"
	" finds that the\n"
	"entrance to the base\n"
	"is locked.\n"
	"The only way to\n"
	" open it is with \n"
	"the seven keys of\n"
	"Krodacia. He must\n"
	"find the keys, the\n"
	"fate of the \n"
	"Universe is in\n"
	"       his hands...       \n"
	"               "

# Princess Lindsay:

%string ck4_str_lindsaySays "Lt. Barker says:     \n"
%string ck4_str_lindsayMessage1 "Thanks for rescuing \n"
				"me! I would have jumped\n"
				"out, but its too dark\n"
				"in here!\n"

%string ck4_str_lindsayMessage2	"You can get a swim    \n"
				"coin in Monk's house.\n"
				"Good luck Commander \n"
				"Keen! \n"

%string ck4_str_lindsayThanks1	"No problem. Lets go!  "
%string ck4_str_lindsayThanks2	"Thanks for the\n"
				"good advice, Lt.\n"
				"Barker!  \n"

# Oracle Janitor:

%string ck4_str_janitor1	"Thanks for going to all\n"
		 		"that trouble, but I'm\n"
				"just the janitor for the\n"
				"High Council."

%string ck4_str_janitor2	"I tried to tell the\n"
				"Shikadi that but they\n"
				"just wouldn't listen..."

%string ck4_str_janitor3	"This had better\n"
				"be a joke."

%string ck4_str_janitor4	"Sorry.  You aren't\n"
				"mad, are you?"

# Wetsuit:

%string ck4_str_cantSwim	"I need a coin"
%string ck4_str_gotWetsuit	"A swim coin! I bet I\n"
				"can use this!   "

