; wizball.gptk - gptokeyb2 config (INI)
; Mappings:
;  Start -> '1'
;  Select/Back -> 'ESC'
;  DPad -> Arrow keys
;  A -> 'x'
;  B -> 'z'
;  Left stick also -> Arrow keys (optional, but useful)

[global]
deadzone = 8000
; You can raise deadzone if the stick drifts (e.g. 12000)

[controls]
; --- Face buttons ---
a = x
b = z

; --- Start / Select ---
start = 1
back  = esc

; --- D-pad ---
up = up
down = down
left = left
right = right

; --- Left stick -> arrows (digital) ---
left_analog_up = up
left_analog_down = down
left_analog_left = left
left_analog_right = right
