#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="$GAMEDIR/patchlog.txt"
LOGERR="$GAMEDIR/patcherr.txt"
START_TIME=$(date +%s)

# Redirect output and error to the log file
exec > >(tee -a "$LOGFILE") 2>&1
echo "GAMEDIR is set to: $GAMEDIR"

# Patch failure function
patch_failure() {
    mv "$LOGFILE" "$LOGERR"
    $ESUDO umount "$TOOLKIT" 2>/dev/null
    echo "Patching process failed."
    exit 1
}

# Mount the GMToolkit runtime
TOOLKIT="$HOME/gmtoolkit"
RUNTIME="$controlfolder/libs/gmtoolkit.squashfs"
if [ -f "$RUNTIME" ]; then
    $ESUDO mkdir -p "$TOOLKIT"
    $ESUDO umount "$RUNTIME" || true
    $ESUDO mount "$RUNTIME" "$TOOLKIT"
else
    echo "This port requires the GMToolkit runtime. Please download it."
    sleep 2
    patch_failure
fi

# Exports
export PATH="$controlfolder:$TOOLKIT/gmtools:$PATH"
export LD_LIBRARY_PATH="/usr/lib:$TOOLKIT/libs:$LD_LIBRARY_PATH"
export SDL_GAMECONTROLLERCONFIG="$sdl_controllerconfig"
export DATADIR="$GAMEDIR/assets"
export DATAFILE="$GAMEDIR/game.port"
export TMPDIR="$GAMEDIR/tmp"

# Permissions
chmod 666 /dev/uinput 2>/dev/null || true

# Set up trap for cleaning TMPDIR on exit
trap 'rm -rf "$TMPDIR"; echo "Cleaned up temporary files." >> "$LOGFILE"' 0

# Attempt to get SAVEDIR from gmloader.json using jq
if command -v jq >/dev/null 2>&1; then
    SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    [ -z "$SAVEDIR" ] && SAVEDIR="$GAMEDIR/saves"
    [[ "$SAVEDIR" != /* ]] && SAVEDIR="$GAMEDIR/$SAVEDIR"
else
    SAVEDIR="$GAMEDIR/saves"
fi

# Test for required commands
PYTHON=$(command -v python3)
if [ -z "$PYTHON" ]; then
    echo "Missing python3!"
    patch_failure
fi

ZIP=$(command -v zip)
if [ -z "$ZIP" ]; then
    echo "Missing zip!"
    patch_failure
fi

prepare_files() {
    mkdir -p "$SAVEDIR"
    mkdir -p "$TMPDIR"
    # Drop anything we don't need from a user-provided dump
    rm -rf "$DATADIR"/*.exe "$DATADIR"/*.dll "$DATADIR"/*.zip "$DATADIR"/.gitkeep
    sleep 1
}

apply_rspatch() {
    # Idempotent: if a previous run already produced game.droid, skip.
    if [ -f "$DATADIR/game.droid" ]; then
        echo "game.droid already exists, skipping rspatch."
        return 0
    fi
    if [ ! -f "$DATADIR/data.win" ]; then
        echo "No data.win file found to patch!"
        patch_failure
    fi
    $PYTHON "$GAMEDIR/tools/patch_apply.py" \
        "$DATADIR/data.win" \
        "$GAMEDIR/rusty_seas.rspatch" \
        "$DATADIR/game.droid"
    if [ $? -ne 0 ]; then
        echo "[RSPATCH]: Failed."
        patch_failure
    fi
    # data.win stays put until the whole pipeline succeeds, so a mid-run
    # failure doesn't force the user to re-copy 189MB.
    sleep 1
}

compress_audio() {
    if $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/game.droid"; then
        mv "$TMPDIR/"* "$DATADIR" && rmdir "$TMPDIR"
        echo "Audio compression applied successfully."
    else
        echo "Audio compression failed for game.droid."
        rmdir "$TMPDIR" 2>/dev/null
        patch_failure
    fi
    sleep 1
    # Recompress loose .ogg files in the asset dir at 64 kbps
    find "$DATADIR" -type f -name "*.ogg" | while read -r file; do
        temp_file="${file%.ogg}_temp.ogg"
        if "$TOOLKIT/gmtools/oggdec" -o - "$file" 2>/dev/null | "$TOOLKIT/gmtools/oggenc" -b 64 -o "$temp_file" - 2>/dev/null; then
            mv "$temp_file" "$file"
            echo "Compressed: $file to 64 kbps"
        else
            echo "Failed to compress: $file" >&2
            rm -f "$temp_file"
        fi
    done
    echo "All .ogg files have been processed."
    sleep 1
}

zip_archive() {
    # Append the compressed game.droid into the shipped game.port.
    # data.win was kept around until now in case something upstream failed.
    cd "$GAMEDIR"
    rm -f "$DATADIR/data.win"
    zip -r -0 "$DATAFILE" ./assets/
    echo "Zipped contents to $DATAFILE"
    rm -rf "$GAMEDIR/assets/"*
    sleep 1
}

install_complete() {
    touch "$GAMEDIR/install_completed"
    END_TIME=$(date +%s)
    DURATION=$((END_TIME - START_TIME))
    echo "Script completed in $DURATION seconds"
    echo "Installation completed successfully!"
    echo "-----------------------------"
    echo "Process finished at: $(date)"
}

process_game() {
    echo "Preparing game..."
    prepare_files || patch_failure
    echo "Applying rspatch to data.win..."
    apply_rspatch || patch_failure
    echo "Compressing audio..."
    compress_audio || patch_failure
    echo "Finishing up..."
    zip_archive || patch_failure
    install_complete
    sleep 1
    $ESUDO umount "$TOOLKIT" 2>/dev/null
    echo "Patching process complete!"
}

process_game
