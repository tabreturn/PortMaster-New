#!/bin/sh

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
brightness_nextui="$("$SCRIPT_DIR/nextUiSettings" brightness)"

# Validate numeric
case "$brightness_nextui" in
    ''|*[!0-9]*)
        echo 155
        exit 1
        ;;
esac

case "$brightness_nextui" in
    0) echo 4 ;;
    1) echo 8 ;;
    2) echo 16 ;;
    3) echo 32 ;;
    4) echo 48 ;;
    5) echo 72 ;;
    6) echo 96 ;;
    7) echo 128 ;;
    8) echo 160 ;;
    9) echo 192 ;;
    10) echo 255 ;;
    *) echo 155; exit 1 ;;
esac